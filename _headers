# Cloudflare Pages — header per AI Seller
# CORS aperto: il widget sul sito del cliente deve poter leggere la config (cross-origin)
/*
  Access-Control-Allow-Origin: *
  Access-Control-Allow-Methods: GET, OPTIONS
  Access-Control-Allow-Headers: Content-Type

# le config si aggiornano spesso (le gestiamo da dietro) → cache breve
/clients/*
  Cache-Control: public, max-age=300, must-revalidate

# widget e app: cache moderata
/widget.js
  Cache-Control: public, max-age=600
